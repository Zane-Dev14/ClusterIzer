graph TD
    Start["Slack User Query:<br/>'@kubesentinel help me'"]
    
    Start -->|SocketMode WebSocket| SlackBot["slack_bot.py<br/>Message Handler"]
    
    SlackBot -->|call| RunAnalysis["run_analysis()<br/>parse user query & cache check"]
    
    RunAnalysis -->|call| RunEngine["runtime.run_engine()<br/>initialize InfraState"]
    
    RunEngine -->|call| GetGraph["runtime.get_graph()<br/>get or build LangGraph"]
    
    GetGraph -->|call| BuildGraph["runtime.build_runtime_graph()<br/>construct execution graph"]
    
    BuildGraph -->|create nodes| LGNode1["LangGraph Node<br/>scan_cluster"]
    LGNode1 -->|imports| CRDModule["crd_discovery.py<br/>discover custom resources"]
    LGNode1 -->|imports| DiagModule["diagnostics/<br/>fetch pod logs"]
    
    BuildGraph -->|create nodes| LGNode2["LangGraph Node<br/>load_desired_state"]
    LGNode2 -->|imports| GitLoader["git_loader.py<br/>load desired state from Git"]
    
    BuildGraph -->|create nodes| LGNode3["LangGraph Node<br/>build_graph"]
    LGNode3 -->|execute| GBModule["graph_builder.py<br/>build cluster graph"]
    
    BuildGraph -->|create nodes| LGNode4["LangGraph Node<br/>generate_signals"]
    LGNode4 -->|execute| SigModule["signals.py<br/>generate risk signals"]
    
    BuildGraph -->|create nodes| LGNode5["LangGraph Node<br/>compute_risk"]
    LGNode5 -->|execute| RiskModule["risk.py<br/>compute risk scores"]
    
    BuildGraph -->|create nodes| LGNode6["LangGraph Node<br/>planner"]
    LGNode6 -->|execute| AgentsModule1["agents.py<br/>planner_node()"]
    
    BuildGraph -->|create nodes| LGNode7["LangGraph Node<br/>run_agents_parallel"]
    LGNode7 -->|execute| AgentsModule2["agents.py<br/>failure/cost/security agents"]
    
    BuildGraph -->|create nodes| LGNode8["LangGraph Node<br/>synthesizer"]
    LGNode8 -->|execute| AgentsModule3["agents.py<br/>synthesizer_node()"]
    
    BuildGraph -->|create nodes| LGNode9["LangGraph Node<br/>END"]
    
    LGNode1 --> ExecuteChain["invoke() executes<br/>entire pipeline"]
    LGNode2 --> ExecuteChain
    LGNode3 --> ExecuteChain
    LGNode4 --> ExecuteChain
    LGNode5 --> ExecuteChain
    LGNode6 --> ExecuteChain
    LGNode7 --> ExecuteChain
    LGNode8 --> ExecuteChain
    
    ExecuteChain -->|returns| State["InfraState<br/>(final analysis results)"]
    
    State -->|call| BuildReport["reporting.build_report()<br/>format findings & risks"]
    
    BuildReport -->|finalize| FinalState["InfraState with<br/>final_report field"]
    
    FinalState -->|return to| RunAnalysis
    RunAnalysis -->|format| FormatSummary["format_summary()<br/>create Slack blocks"]
    
    FormatSummary -->|reply| SlackReply["Slack thread reply<br/>with analysis results<br/>& action buttons"]
